# =========================================================
# Copier ce fichier en .env.local et remplir avec tes vraies valeurs.
# .env.local ne doit JAMAIS être commité (déjà dans .gitignore).
# =========================================================

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ Secrète — jamais exposée au navigateur, jamais préfixée NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Developers > API keys (utiliser les clés TEST au départ)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
# Généré par `stripe listen` en local, ou par le dashboard Stripe en prod
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# URL publique du site (utilisée pour les métadonnées SEO et les redirections Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
